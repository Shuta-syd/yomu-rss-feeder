# Yomu 環境変数テンプレート
# 実運用では `.env` にコピーして値を埋めてください

# APIキー暗号化用 (必須)
# 生成: openssl rand -hex 32
ENCRYPTION_KEY=

# Web Push通知用 VAPID 鍵 (任意、通知を使う場合に必要)
# 生成: make vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Cloudflare Tunnel Token (任意、外部公開する場合に使用)
# Zero Trust Dashboard → Networks → Tunnels → Create tunnel で取得
CLOUDFLARE_TUNNEL_TOKEN=
