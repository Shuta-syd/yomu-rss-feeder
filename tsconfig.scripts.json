{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["esnext"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src/scripts",
    "declaration": false,
    "resolveJsonModule": true
  },
  "include": ["src/scripts/**/*.ts"],
  "exclude": ["node_modules", ".next", "dist"]
}
